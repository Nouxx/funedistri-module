<?xml version="1.0" encoding="utf-8"?>
<!--
  Step 5 — locked company address book (ADR 0005), UI half.

  Hide the "Add Address" button on the DELIVERY address picker for a B2B user
  (Salesman / Store owner). They may only SELECT among the company's Owner-defined
  delivery addresses. This is UX only — the security boundary is server-side in
  controllers/address_lock.py (a crafted request is refused there). The billing
  picker is untouched (delivery-only scope).

  groups="!a,!b" → shown unless the user is in group a OR b (i.e. hidden for both
  B2B roles, shown for staff / non-B2B).
-->
<odoo>
    <template id="delivery_address_list_lock" inherit_id="website_sale.delivery_address_list">
        <xpath expr="//a[hasclass('o_address_card_add_new')]" position="attributes">
            <attribute name="groups">!funedistri_customizations.coffin_salesman_group,!funedistri_customizations.coffin_store_owner_group</attribute>
        </xpath>
    </template>

    <!-- Portal /my/addresses: mark the address section for a B2B user so CSS
         (static/src/css/coffin_address_lock.css) visually disables the add/edit/
         remove controls — they're server-blocked, this conveys it. -->
    <template id="portal_my_addresses_lock" inherit_id="portal.my_addresses">
        <xpath expr="//section[hasclass('o_portal_addresses')]" position="attributes">
            <attribute name="class"/>
            <attribute name="t-attf-class">o_portal_addresses {{'coffin-addr-locked' if request.env.user._coffin_is_b2b_user() else ''}}</attribute>
        </xpath>
    </template>

    <!-- Same for the BILLING picker (Step 5b: billing is locked too). Its add
         button uses t-attf-class (dynamic), so hasclass() can't match it — target
         it by its t-att-href instead. -->
    <template id="billing_address_list_lock" inherit_id="website_sale.billing_address_list">
        <xpath expr="//a[@t-att-href='new_address_url']" position="attributes">
            <attribute name="groups">!funedistri_customizations.coffin_salesman_group,!funedistri_customizations.coffin_store_owner_group</attribute>
        </xpath>
        <!-- Mark the billing block so the CSS disables the "Same as delivery
             address" toggle for a B2B user (it would set billing to a delivery
             address). -->
        <xpath expr="//div[@id='billing_address_list']" position="attributes">
            <attribute name="class"/>
            <attribute name="t-attf-class">mb-3 pt-2 {{'coffin-addr-locked' if request.env.user._coffin_is_b2b_user() else ''}}</attribute>
        </xpath>
    </template>
</odoo>
