<?xml version="1.0" encoding="utf-8"?>
<!--
  Step 5 — locked company address book (ADR 0005), UI half.

  Hide the "Add Address" button on the DELIVERY address picker for a B2B user
  (Salesman / Store owner). They may only SELECT among the company's Owner-defined
  delivery addresses. This is UX only — the security boundary is server-side in
  controllers/address_lock.py (a crafted request is refused there). The billing
  picker is untouched (delivery-only scope).

  groups="!a,!b" → shown unless the user is in group a OR b (i.e. hidden for both
  B2B roles, shown for staff / non-B2B).
-->
<odoo>
    <!-- Disable the ADDRESS-step "continue" button (not the cart's Checkout button)
         when a B2B user's company is missing a required address — so the user can
         reach the address step and be blocked THERE. Keyed on the current step
         being /shop/checkout, so the cart's own button (same template) stays
         enabled. -->
    <template id="navigation_buttons_lock" inherit_id="website_sale.navigation_buttons">
        <!-- coffin_blocked: on the address step, a B2B user whose company lacks a
             required address. Disable the continue button AND make it genuinely
             unclickable — class 'disabled' (pointer-events:none) is not enough for
             an <a> (keyboard / href still work), so we also neutralise href and set
             aria-disabled/tabindex. -->
        <xpath expr="//a[@name='website_sale_main_button']" position="before">
            <t t-set="coffin_blocked"
               t-value="current_website_checkout_step_href == '/shop/checkout'
                        and request.env.user._coffin_is_b2b_user()
                        and website_sale_order._coffin_addresses_blocked()"/>
        </xpath>
        <xpath expr="//a[@name='website_sale_main_button']" position="attributes">
            <attribute name="t-attf-class">btn btn-primary #{(not website_sale_order._is_cart_ready() or coffin_blocked) and 'disabled'} w-100</attribute>
            <attribute name="t-att-href">'#' if coffin_blocked else next_website_checkout_step_href</attribute>
            <attribute name="t-att-aria-disabled">coffin_blocked and 'true' or None</attribute>
            <attribute name="t-att-tabindex">coffin_blocked and '-1' or None</attribute>
        </xpath>
    </template>

    <template id="delivery_address_list_lock" inherit_id="website_sale.delivery_address_list">
        <xpath expr="//a[hasclass('o_address_card_add_new')]" position="attributes">
            <attribute name="groups">!funedistri_customizations.coffin_salesman_group,!funedistri_customizations.coffin_store_owner_group</attribute>
        </xpath>
        <!-- B2B + no company delivery address → explain the disabled checkout. -->
        <xpath expr="//div[@id='delivery_address_list']" position="inside">
            <div t-if="request.env.user._coffin_is_b2b_user() and not order._coffin_company_has_address('delivery')"
                 class="alert alert-warning mt-2" role="status">
                Aucune adresse de livraison n'est définie pour votre société.
                Contactez Funedistri pour pouvoir commander.
            </div>
        </xpath>
    </template>

    <!-- Portal /my/addresses: mark the address section for a B2B user so CSS
         (static/src/css/coffin_address_lock.css) visually disables the add/edit/
         remove controls — they're server-blocked, this conveys it. -->
    <template id="portal_my_addresses_lock" inherit_id="portal.my_addresses">
        <xpath expr="//section[hasclass('o_portal_addresses')]" position="attributes">
            <attribute name="class"/>
            <attribute name="t-attf-class">o_portal_addresses {{'coffin-addr-locked' if request.env.user._coffin_is_b2b_user() else ''}}</attribute>
        </xpath>
    </template>

    <!-- Same for the BILLING picker (Step 5b: billing is locked too). Its add
         button uses t-attf-class (dynamic), so hasclass() can't match it — target
         it by its t-att-href instead. -->
    <template id="billing_address_list_lock" inherit_id="website_sale.billing_address_list">
        <xpath expr="//a[@t-att-href='new_address_url']" position="attributes">
            <attribute name="groups">!funedistri_customizations.coffin_salesman_group,!funedistri_customizations.coffin_store_owner_group</attribute>
        </xpath>
        <!-- Mark the billing block so the CSS disables the "Same as delivery
             address" toggle for a B2B user (it would set billing to a delivery
             address). -->
        <xpath expr="//div[@id='billing_address_list']" position="attributes">
            <attribute name="class"/>
            <attribute name="t-attf-class">mb-3 pt-2 {{'coffin-addr-locked' if request.env.user._coffin_is_b2b_user() else ''}}</attribute>
        </xpath>
        <!-- B2B + no company invoice address → explain the disabled checkout. -->
        <xpath expr="//div[@id='billing_address_list']" position="inside">
            <div t-if="request.env.user._coffin_is_b2b_user() and not order._coffin_company_has_address('invoice')"
                 class="alert alert-warning mt-2" role="status">
                Aucune adresse de facturation n'est définie pour votre société.
                Contactez Funedistri pour pouvoir commander.
            </div>
        </xpath>
    </template>
</odoo>
