<?xml version="1.0" encoding="utf-8"?>
<!--
  Step 1.5 — show the Order's state in the B2B user's portal list, so a
  submitted Order reads "En attente de validation" (Pending), never "Quotation".
  Pairs with the _prepare_orders_domain override (controllers/main.py) that makes
  submitted drafts appear in /my/orders at all.
-->
<odoo>

    <template id="portal_my_orders_status"
              inherit_id="sale.portal_my_orders"
              name="Coffin: Pending status column">

        <!-- Header: add a "Statut" column after the Total column. -->
        <xpath expr="//th[@name='order_total']" position="after">
            <th class="text-end">Statut</th>
        </xpath>

        <!-- Row: a badge per order. Our Pending Orders are draft + submitted;
             a validated Order is in state 'sale'. We never print "Quotation". -->
        <xpath expr="//td[@name='order_amount_total']" position="after">
            <td class="text-end">
                <span t-if="order.state == 'sale'"
                      class="badge rounded-pill text-bg-success">
                    Validée
                </span>
                <span t-elif="order.state == 'draft' and order.coffin_is_submitted"
                      class="badge rounded-pill text-bg-warning">
                    En attente de validation
                </span>
            </td>
        </xpath>
    </template>

</odoo>
