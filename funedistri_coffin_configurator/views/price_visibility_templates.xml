<?xml version="1.0" encoding="utf-8"?>
<!--
  Step 6 — price masking for the SALESMAN (see ADR-0001).

  A Salesman places orders blind to price; a Store owner of the same company
  sees prices. This file does the RENDER-side half: across the interactive
  shopping surfaces (shop grid, product page, cart, checkout totals) and the
  portal order list, a Salesman gets a "Prix masqué" placeholder instead of any
  number. The JSON-route half (so the real number is never emitted in the
  cart/checkout JSON either) lives in controllers/main.py. Email/PDF and the
  portal order DETAIL page render the order *document* in owner/system context
  and key off the order partner's role — that is Step 7, not here.

  Mechanism: the `groups` attribute. Odoo strips any node whose `groups` the
  current user is NOT in; a leading `!` negates. So we tag the REAL price node
  `groups="!...coffin_salesman_group"` (everyone EXCEPT a salesman renders it)
  and add a sibling placeholder `groups="...coffin_salesman_group"` (only a
  salesman renders it). This is purely server-side: for a salesman the number
  node is never emitted into the HTML at all — not hidden by CSS. That is the
  ADR-0001 guardrail (a CSS/JS cover over a real number would fail the bar).

  WHY `groups` and not `t-if has_group(...)`: same effect, but `groups` is the
  idiomatic, declarative form, reads cleaner, and matches how Odoo core gates
  price-ish nodes (e.g. portal uses `groups="!..."` too).

  Important: masking is PRACTICAL, not adversary-proof (ADR-0001). We suppress
  the rendered number and the main JSON routes; we do NOT chase every variant-
  price recompute route. A determined salesman with dev tools is out of scope.
-->
<odoo>

    <!-- The placeholder a Salesman sees in place of any price. Defined once,
         t-call'd from every masked surface so the wording/tooltip live in ONE
         place. FR locale (the site sells in euros to French customers). -->
    <template id="coffin_price_masked" name="Coffin: masked price placeholder">
        <span
            class="text-muted fst-italic coffin-price-masked"
            title="Prix masqué : en tant que commercial vous commandez sans voir les prix. Le gérant du magasin (Store owner) voit les prix."
        >Prix masqué</span>
    </template>

    <!-- 1) PRODUCT PRICE — shared by the /shop grid tile AND the product page
         (both t-call 'website_sale.product_price'), so this one override masks
         both. We hide the whole price container (main price + struck-through
         list/compare prices) and drop the placeholder in its place. -->
    <template id="product_price_salesman_mask" inherit_id="website_sale.product_price">
        <xpath expr="//div[@name='product_price_container']" position="attributes">
            <attribute name="groups">!funedistri_coffin_configurator.coffin_salesman_group</attribute>
        </xpath>
        <xpath expr="//div[@name='product_price_container']" position="after">
            <div
                groups="funedistri_coffin_configurator.coffin_salesman_group"
                class="css_editable_mode_hidden h5 mb-0"
            >
                <t t-call="funedistri_coffin_configurator.coffin_price_masked"/>
            </div>
        </xpath>
    </template>

    <!-- 2) CART LINE PRICE — the per-line price block on the cart page (unit
         price + line subtotal + any strikethrough). Hide the whole <h6> and
         show the placeholder instead. -->
    <template id="cart_line_price_salesman_mask" inherit_id="website_sale.cart_lines_price">
        <xpath expr="//h6[@name='website_sale_cart_line_price']" position="attributes">
            <attribute name="groups">!funedistri_coffin_configurator.coffin_salesman_group</attribute>
        </xpath>
        <xpath expr="//h6[@name='website_sale_cart_line_price']" position="after">
            <h6 groups="funedistri_coffin_configurator.coffin_salesman_group" class="mb-1">
                <t t-call="funedistri_coffin_configurator.coffin_price_masked"/>
            </h6>
        </xpath>
    </template>

    <!-- 3) CART / CHECKOUT TOTALS — the totals table (delivery, subtotal, taxes,
         total, and the coupon row inherited into it). Hide the whole o_cart_total
         block and show a single placeholder. We keep the original render guard
         (only when there's an order with lines) on the placeholder too. -->
    <template id="total_salesman_mask" inherit_id="website_sale.total">
        <xpath expr="//div[contains(@t-attf-class, 'o_cart_total')]" position="attributes">
            <attribute name="groups">!funedistri_coffin_configurator.coffin_salesman_group</attribute>
        </xpath>
        <xpath expr="//div[contains(@t-attf-class, 'o_cart_total')]" position="after">
            <div
                groups="funedistri_coffin_configurator.coffin_salesman_group"
                t-if="website_sale_order and website_sale_order.website_order_line"
                t-attf-class="o_cart_total #{_cart_total_classes}"
            >
                <t t-call="funedistri_coffin_configurator.coffin_price_masked"/>
            </div>
        </xpath>
    </template>

    <!-- 4) PORTAL ORDER LIST (/my/orders) — the "Total" column. Mask the amount
         cell so a Salesman's order history shows no totals. (The order DETAIL
         page is Step 7.) -->
    <template id="portal_my_orders_salesman_mask" inherit_id="sale.portal_my_orders">
        <xpath expr="//td[@name='order_amount_total']/span" position="attributes">
            <attribute name="groups">!funedistri_coffin_configurator.coffin_salesman_group</attribute>
        </xpath>
        <xpath expr="//td[@name='order_amount_total']" position="inside">
            <t
                groups="funedistri_coffin_configurator.coffin_salesman_group"
                t-call="funedistri_coffin_configurator.coffin_price_masked"
            />
        </xpath>
    </template>

</odoo>
