<?xml version="1.0" encoding="utf-8"?>
<!--
  Step 1 view overrides for the checkout "flow A" (no online payment):
    1.3 — turn the payment step into a single "Valider la commande" submit.
    1.4 — confirmation page wording: "Commande reçue — en attente de validation".

  These are QWeb template inheritances: we don't copy Odoo's templates, we
  surgically patch them with <xpath>, so future Odoo updates to the originals
  still flow through.
-->
<odoo>

    <!-- 1.3 — Payment step becomes a no-payment "Submit order" step.
         The cart is already a draft sale.order; submitting just hands it to the
         Owner as Pending. So we strip the payment providers and post our own
         button to /shop/submit_order. -->
    <template id="payment_submit_order"
              inherit_id="website_sale.payment"
              name="Coffin: Submit order (no online payment)">

        <!-- Tell the shared navigation_buttons template to hide BOTH the native
             pay/confirm button and the "or" divider. The stock payment template
             uses this very flag for the same purpose, so it propagates into the
             checkout layout's button area. -->
        <xpath expr="//t[@t-set='redirect']" position="after">
            <t t-set="hide_payment_button" t-value="True"/>
        </xpath>

        <!-- Remove the payment-provider widget entirely (no Stripe/etc.). We
             keep the surrounding 'website_sale_non_free_cart' div so its paired
             t-else ("Confirm order" heading) stays valid; we only empty it. -->
        <xpath expr="//div[@id='payment_method']" position="replace">
            <t/>
        </xpath>

        <!-- Our own submit button. A plain POST form to the Step 1 controller.
             csrf_token is required because the route is a state-changing POST. -->
        <xpath expr="//div[@id='address_on_payment']" position="before">
            <form action="/shop/submit_order" method="post"
                  class="mb-3" name="coffin_submit_order">
                <input type="hidden" name="csrf_token"
                       t-att-value="request.csrf_token()"/>
                <button type="submit" class="btn btn-primary btn-lg w-100">
                    Valider la commande
                </button>
            </form>
        </xpath>
    </template>

    <!-- 1.4 — Confirmation page: clear FR "pending validation" message.
         Odoo's native "Thank you for your order." heading is gated on a payment
         transaction (which flow A never creates), so it stays hidden and we add
         our own heading instead. CONTEXT.md wording: never "paid", never
         "quotation" — the Order is Pending ("en attente de validation"). -->
    <template id="confirmation_pending"
              inherit_id="website_sale.confirmation"
              name="Coffin: Pending-validation confirmation">
        <xpath expr="//div[@id='order_name']" position="before">
            <div class="alert alert-success mt-3" role="status"
                 name="coffin_order_received">
                <h3 class="mb-1">Commande reçue</h3>
                <p class="mb-0">
                    Votre commande est en attente de validation.
                </p>
            </div>
        </xpath>
    </template>

</odoo>
