<?xml version="1.0" encoding="utf-8"?>
<!--
  Step 3.1 — native product attributes for the demo Coffin model.

  WHY demo (not data)?
  In production the Owner self-serves these Options via the native Odoo product
  attribute UI (that is the whole point of the "no meta-configurator" decision).
  So we DON'T ship them as `data`; we only seed them in the dev DB as `demo` so
  every `make dev` gives a clickable configurable coffin.

  Two key native settings per attribute:
  - create_variant = 'no_variant'  -> Odoo never explodes the catalog into one
    SKU per combination; the chosen Options are captured on the order LINE
    instead. Avoids combinatorial DB blow-up (CLAUDE.md "no variant" decision).
  - display_type                   -> how the choice renders in the configurator:
    'image' for a wood swatch picker, 'select' for a plain dropdown.
-->
<odoo>
    <data noupdate="1">

        <!-- ============ Option: Bois (Wood) — image picker, priced ============ -->
        <record id="attr_wood" model="product.attribute">
            <field name="name">Bois</field>
            <field name="display_type">image</field>
            <field name="create_variant">no_variant</field>
        </record>

        <record id="attr_wood_oak" model="product.attribute.value">
            <field name="name">Chêne</field>
            <field name="attribute_id" ref="attr_wood"/>
            <field name="sequence">10</field>
            <!-- tiny inline swatch so the 'image' display type has something to
                 show in dev; the Owner replaces these with real photos. -->
            <field name="image">iVBORw0KGgoAAAANSUhEUgAAABAAAAAQCAIAAACQkWg2AAAAFklEQVR4nGOo8NAgCTGMahjVMHw1AACn3egBHUOGvwAAAABJRU5ErkJggg==</field>
        </record>

        <record id="attr_wood_plywood" model="product.attribute.value">
            <field name="name">Contreplaqué</field>
            <field name="attribute_id" ref="attr_wood"/>
            <field name="sequence">20</field>
            <field name="image">iVBORw0KGgoAAAANSUhEUgAAABAAAAAQCAIAAACQkWg2AAAAFklEQVR4nGM4saqCJMQwqmFUw/DVAADPAuoQq2r+KgAAAABJRU5ErkJggg==</field>
        </record>

        <!-- ============ Option: Poignées (Handles) — select, priced ============ -->
        <record id="attr_handles" model="product.attribute">
            <field name="name">Poignées</field>
            <field name="display_type">select</field>
            <field name="create_variant">no_variant</field>
        </record>

        <record id="attr_handles_standard" model="product.attribute.value">
            <field name="name">Standard</field>
            <field name="attribute_id" ref="attr_handles"/>
            <field name="sequence">10</field>
        </record>

        <record id="attr_handles_gold" model="product.attribute.value">
            <field name="name">Dorées</field>
            <field name="attribute_id" ref="attr_handles"/>
            <field name="sequence">20</field>
        </record>

        <!-- ===== Option: Gravure (Yes/No) — informational, no price =====
             Modelled as a native attribute (Step 4 decision) so its "Oui" value
             can be the TRIGGER of a reveal rule (-> death date + engraving text).
             Unpriced: no price_extra on its PTAVs. -->
        <record id="attr_engraving" model="product.attribute">
            <field name="name">Gravure</field>
            <field name="display_type">radio</field>
            <field name="create_variant">no_variant</field>
        </record>

        <record id="attr_engraving_no" model="product.attribute.value">
            <field name="name">Non</field>
            <field name="attribute_id" ref="attr_engraving"/>
            <field name="sequence">10</field>
        </record>

        <record id="attr_engraving_yes" model="product.attribute.value">
            <field name="name">Oui</field>
            <field name="attribute_id" ref="attr_engraving"/>
            <field name="sequence">20</field>
        </record>

    </data>
</odoo>
