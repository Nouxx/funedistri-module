<?xml version="1.0" encoding="utf-8"?>
<!--
  Step 3.3 — demo B2B accounts so every `make dev` has both roles to click.

  Company-scoped visibility is NATIVE (CLAUDE.md): if all of a company's B2B
  users are CONTACTS UNDER THE SAME PARENT company, they share one
  commercial_partner_id, and Odoo's portal record rules then scope each user to
  that company's documents. So the only requirement is data shape — set
  parent_id to the company. No code.

  res.users _inherits res.partner, so partner fields (parent_id, b2b_role,
  address, email) can be set directly on the user record; they delegate to its
  linked contact. Setting b2b_role here triggers our res.users.create sync, which
  drops the user into the matching hidden security group automatically.
-->
<odoo>
    <data noupdate="1">

        <!-- The customer company every demo B2B user sits under. -->
        <record id="demo_company" model="res.partner">
            <field name="name">Pompes Funèbres Demo SARL</field>
            <field name="is_company">True</field>
            <field name="street">5 rue des Lilas</field>
            <field name="city">Nantes</field>
            <field name="zip">44000</field>
            <field name="country_id" ref="base.fr"/>
            <field name="email">contact@pf-demo.example.com</field>
        </record>

        <!-- Store owner: sees prices. Contact under the company. -->
        <record id="demo_user_store_owner" model="res.users">
            <field name="name">Demo Store Owner</field>
            <field name="login">demo_store_owner</field>
            <field name="password">demo_store_owner</field>
            <field name="group_ids" eval="[Command.set([ref('base.group_portal')])]"/>
            <field name="parent_id" ref="demo_company"/>
            <field name="b2b_role">store_owner</field>
            <field name="email">store.owner@pf-demo.example.com</field>
            <field name="phone">+33240000001</field>
            <field name="street">5 rue des Lilas</field>
            <field name="city">Nantes</field>
            <field name="zip">44000</field>
            <field name="country_id" ref="base.fr"/>
        </record>

        <!-- Salesman: places orders for the company, will see NO prices once
             masking ships. Same parent company -> shares order history. -->
        <record id="demo_user_salesman" model="res.users">
            <field name="name">Demo Salesman</field>
            <field name="login">demo_salesman</field>
            <field name="password">demo_salesman</field>
            <field name="group_ids" eval="[Command.set([ref('base.group_portal')])]"/>
            <field name="parent_id" ref="demo_company"/>
            <field name="b2b_role">salesman</field>
            <field name="email">salesman@pf-demo.example.com</field>
            <field name="phone">+33240000002</field>
            <field name="street">5 rue des Lilas</field>
            <field name="city">Nantes</field>
            <field name="zip">44000</field>
            <field name="country_id" ref="base.fr"/>
        </record>

    </data>
</odoo>
