<?xml version="1.0" encoding="utf-8"?>
<!--
  Step 3.2 — the demo Coffin model: a configurable product.template wired to the
  native attributes from coffin_attributes.xml, with per-option prices.

  This REPLACES the Step 1 tracer coffin (data/tracer_coffin.xml, removed). Demo
  only: prod starts empty and the Owner builds their own Coffin models.
-->
<odoo>
    <data noupdate="1">

        <!-- The base coffin. list_price = the starting price; each chosen Option
             adds its price_extra on top, captured on the order line. -->
        <record id="coffin_demo" model="product.template">
            <field name="name">Cercueil configurable</field>
            <field name="type">consu</field>
            <field name="sale_ok">True</field>
            <field name="list_price">600.0</field>
            <field name="is_published">True</field>
        </record>

        <!-- Attribute LINES: attach each Option (and which of its values are
             offered) to this coffin. Creating a line auto-creates one
             product.template.attribute.value (PTAV) per value_id, in order. -->
        <record id="coffin_demo_line_wood" model="product.template.attribute.line">
            <field name="product_tmpl_id" ref="coffin_demo"/>
            <field name="attribute_id" ref="attr_wood"/>
            <field name="value_ids"
                   eval="[Command.set([ref('attr_wood_oak'), ref('attr_wood_plywood')])]"/>
        </record>

        <record id="coffin_demo_line_handles" model="product.template.attribute.line">
            <field name="product_tmpl_id" ref="coffin_demo"/>
            <field name="attribute_id" ref="attr_handles"/>
            <field name="value_ids"
                   eval="[Command.set([ref('attr_handles_standard'), ref('attr_handles_gold')])]"/>
        </record>

        <!-- Gravure option on the coffin: the trigger for the reveal rules. -->
        <record id="coffin_demo_line_engraving" model="product.template.attribute.line">
            <field name="product_tmpl_id" ref="coffin_demo"/>
            <field name="attribute_id" ref="attr_engraving"/>
            <field name="value_ids"
                   eval="[Command.set([ref('attr_engraving_no'), ref('attr_engraving_yes')])]"/>
        </record>

        <!-- price_extra lives on the auto-created PTAVs, which have no xmlid of
             their own. Odoo's own demo solves this by registering xmlids onto
             them via ir.model.data._update_xmlids, indexing product_template_
             value_ids in value_ids order. Then we can set price_extra below. -->
        <function model="ir.model.data" name="_update_xmlids">
            <value model="base" eval="[
                {'xml_id': 'funedistri_coffin_configurator.ptav_wood_oak',
                 'record': obj().env.ref('funedistri_coffin_configurator.coffin_demo_line_wood').product_template_value_ids[0],
                 'noupdate': True},
                {'xml_id': 'funedistri_coffin_configurator.ptav_wood_plywood',
                 'record': obj().env.ref('funedistri_coffin_configurator.coffin_demo_line_wood').product_template_value_ids[1],
                 'noupdate': True},
                {'xml_id': 'funedistri_coffin_configurator.ptav_handles_standard',
                 'record': obj().env.ref('funedistri_coffin_configurator.coffin_demo_line_handles').product_template_value_ids[0],
                 'noupdate': True},
                {'xml_id': 'funedistri_coffin_configurator.ptav_handles_gold',
                 'record': obj().env.ref('funedistri_coffin_configurator.coffin_demo_line_handles').product_template_value_ids[1],
                 'noupdate': True},
            ]"/>
        </function>

        <!-- The actual prices. Base values (oak, standard handles) stay +0. -->
        <record id="ptav_wood_plywood" model="product.template.attribute.value">
            <field name="price_extra">120.0</field>
        </record>
        <record id="ptav_handles_gold" model="product.template.attribute.value">
            <field name="price_extra">80.0</field>
        </record>

    </data>
</odoo>
