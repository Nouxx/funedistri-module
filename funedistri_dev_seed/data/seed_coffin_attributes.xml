<?xml version="1.0" encoding="utf-8"?>
<!--
  LOCAL DEV SEED — coffin Options (native product attributes + values).

  Captured from the dev DB the Owner configured by hand (the "Cercueil Taica"
  setup), so every fresh `make dev` rebuilds the same clickable configurator
  without re-entering it. In PRODUCTION the Owner self-serves these via the
  native Odoo attribute UI — that is the whole point of the "no meta-configurator"
  decision — so they are NOT shipped as prod `data`; they live here, in the
  local-only seed module.

  Key native settings per attribute:
  - create_variant = 'no_variant'  → Odoo never explodes the catalog into one
    SKU per combination; the chosen Options are captured on the sale order LINE.
    (CLAUDE.md decision. The live DB the Owner built used 'dynamic'; we normalise
    the seed back to 'no_variant' on purpose.)
  - display_type                   → how the choice renders: 'image' = picture
    picker, 'select' = dropdown, 'radio' = radio buttons.

  Prices live on each VALUE as `default_extra_price`: when a product is built
  from these attributes, its per-line price_extra defaults from this number.
  Only non-zero extras are written; the rest default to 0.

  Images: the Owner uploaded real photos for some image-type values. Embedding
  real photos here would bloat the seed, so we ship a tiny 16x16 placeholder
  swatch (just so the 'image' picker has something to render). The Owner
  replaces these with real pictures in the UI.

  noupdate="1" → created once; reseed = drop DB (make reset) + make dev.
-->
<odoo>
    <data noupdate="1">

        <!-- ============ Longeur (cm) — radio, no price ============ -->
        <record id="attr_longueur" model="product.attribute">
            <field name="name">Longeur (cm)</field>
            <field name="display_type">radio</field>
            <field name="create_variant">no_variant</field>
        </record>
        <record id="val_longueur_185" model="product.attribute.value">
            <field name="name">185</field>
            <field name="attribute_id" ref="attr_longueur"/>
            <field name="sequence">0</field>
        </record>
        <record id="val_longueur_195" model="product.attribute.value">
            <field name="name">195</field>
            <field name="attribute_id" ref="attr_longueur"/>
            <field name="sequence">1</field>
        </record>
        <record id="val_longueur_custom" model="product.attribute.value">
            <field name="name">Sur mesure</field>
            <field name="attribute_id" ref="attr_longueur"/>
            <field name="sequence">2</field>
        </record>

        <!-- ============ Largueur (cm) — radio, no price ============ -->
