<?xml version="1.0" encoding="utf-8"?>
<!--
  LOCAL DEV SEED — test B2B accounts.

  Two customer companies, three portal users:
    Company A  ->  one STORE_OWNER (sees prices) + one SALESMAN (price-blind)
    Company B  ->  one SALESMAN

  WHY THIS SHAPE
  Company-scoped order visibility is NATIVE in Odoo: portal users only see the
  documents of their own company. That company is their commercial_partner_id,
  derived from parent_id. So each user is a CONTACT UNDER its company
  (parent_id = the company record). Company A's two users share a company, so a
  store owner can review what their salesman submitted. Company B's salesman is
  under a DIFFERENT company, which lets us verify users never see another
  company's orders.

  HOW THE ROLE WORKS
  res.users _inherits res.partner, so partner fields (parent_id, b2b_role,
  address) can be set straight on the user record — they delegate to the linked
  contact. Setting b2b_role fires funedistri_customizations' res.users.create
  sync, which drops the user into the matching hidden security group (salesman /
  store_owner) automatically. We don't touch groups here beyond base.group_portal
  (= a website/portal user, never a backend user).

  noupdate="1" → these records are created ONCE and not overwritten on a module
  upgrade. To reseed from scratch, drop the DB (make reset) and make dev again.
-->
<odoo>
    <data noupdate="1">

        <!-- ============================ COMPANY A ============================ -->
        <record id="seed_company_a" model="res.partner">
            <field name="name">Company A — Pompes Funèbres</field>
            <field name="is_company">True</field>
            <field name="street">10 rue de la Paix</field>
            <field name="city">Nantes</field>
            <field name="zip">44000</field>
            <field name="country_id" ref="base.fr"/>
            <field name="email">contact@company-a.example.com</field>
        </record>

        <!-- Company A — STORE OWNER: places orders AND sees prices. -->
        <record id="seed_a_store_owner" model="res.users">
            <field name="name">Company A — Store Owner</field>
            <field name="login">a_store_owner</field>
            <field name="password">a_store_owner</field>
            <field name="group_ids" eval="[Command.set([ref('base.group_portal')])]"/>
            <field name="parent_id" ref="seed_company_a"/>
            <field name="b2b_role">store_owner</field>
            <field name="email">store.owner@company-a.example.com</field>
            <field name="phone">+33240000011</field>
            <field name="street">10 rue de la Paix</field>
            <field name="city">Nantes</field>
            <field name="zip">44000</field>
            <field name="country_id" ref="base.fr"/>
        </record>

        <!-- Company A — SALESMAN: places orders on the company's behalf, sees
             NO prices anywhere. -->
        <record id="seed_a_salesman" model="res.users">
            <field name="name">Company A — Salesman</field>
            <field name="login">a_salesman</field>
            <field name="password">a_salesman</field>
            <field name="group_ids" eval="[Command.set([ref('base.group_portal')])]"/>
            <field name="parent_id" ref="seed_company_a"/>
            <field name="b2b_role">salesman</field>
            <field name="email">salesman@company-a.example.com</field>
            <field name="phone">+33240000012</field>
            <field name="street">10 rue de la Paix</field>
            <field name="city">Nantes</field>
            <field name="zip">44000</field>
            <field name="country_id" ref="base.fr"/>
        </record>

        <!-- Company A — Owner-defined DELIVERY addresses (ADR 0005). Child
             contacts (type='delivery') of the company; a B2B user may only SELECT
             among these at checkout, never create/edit. -->
        <!-- NB: a delivery address must be COMPLETE (name, email, phone + address)
             or native checkout redirects to edit it — which a B2B user can't. -->
        <record id="seed_a_delivery_1" model="res.partner">
            <field name="name">Company A — Funérarium Centre</field>
            <field name="parent_id" ref="seed_company_a"/>
            <field name="type">delivery</field>
            <field name="email">funerarium.centre@company-a.example.com</field>
            <field name="phone">+33240000051</field>
            <field name="street">5 rue des Lilas</field>
            <field name="city">Nantes</field>
            <field name="zip">44000</field>
            <field name="country_id" ref="base.fr"/>
        </record>
        <record id="seed_a_delivery_2" model="res.partner">
            <field name="name">Company A — Chambre funéraire Sud</field>
            <field name="parent_id" ref="seed_company_a"/>
            <field name="type">delivery</field>
            <field name="email">chambre.sud@company-a.example.com</field>
            <field name="phone">+33240000052</field>
            <field name="street">18 avenue de la Loire</field>
            <field name="city">Rezé</field>
            <field name="zip">44400</field>
            <field name="country_id" ref="base.fr"/>
        </record>

        <!-- ============================ COMPANY B ============================ -->
        <record id="seed_company_b" model="res.partner">
            <field name="name">Company B — Pompes Funèbres</field>
            <field name="is_company">True</field>
            <field name="street">25 avenue Victor Hugo</field>
            <field name="city">Rennes</field>
            <field name="zip">35000</field>
            <field name="country_id" ref="base.fr"/>
            <field name="email">contact@company-b.example.com</field>
        </record>

        <!-- Company B — SALESMAN: different company → must NOT see Company A's
             orders. Used to verify native company-scoped visibility. -->
        <record id="seed_b_salesman" model="res.users">
            <field name="name">Company B — Salesman</field>
            <field name="login">b_salesman</field>
            <field name="password">b_salesman</field>
            <field name="group_ids" eval="[Command.set([ref('base.group_portal')])]"/>
            <field name="parent_id" ref="seed_company_b"/>
            <field name="b2b_role">salesman</field>
            <field name="email">salesman@company-b.example.com</field>
            <field name="phone">+33299000021</field>
            <field name="street">25 avenue Victor Hugo</field>
            <field name="city">Rennes</field>
            <field name="zip">35000</field>
            <field name="country_id" ref="base.fr"/>
        </record>

        <!-- Company B — one Owner-defined delivery address. -->
        <record id="seed_b_delivery_1" model="res.partner">
            <field name="name">Company B — Funérarium Rennes</field>
            <field name="parent_id" ref="seed_company_b"/>
            <field name="type">delivery</field>
            <field name="email">funerarium@company-b.example.com</field>
            <field name="phone">+33299000051</field>
            <field name="street">3 place de la Mairie</field>
            <field name="city">Rennes</field>
            <field name="zip">35000</field>
            <field name="country_id" ref="base.fr"/>
        </record>

        <!-- ===================== ORPHAN (no company) ===================== -->
        <!-- A portal user with NO parent_id → not under any customer company. Its
             commercial_partner_id is therefore itself, so native portal scoping
             limits it to its OWN documents (it placed none) → it sees NO orders,
             and never another company's. This is the misconfigured-account case
             from the plan (Step 6); we use it to PROVE the "orphan sees nothing"
             guarantee, not to grant cross-company access. No b2b_role: it is not a
             configured shopper. -->
        <record id="seed_orphan_user" model="res.users">
            <field name="name">Orphan User (no company)</field>
            <field name="login">orphan</field>
            <field name="password">orphan</field>
            <field name="group_ids" eval="[Command.set([ref('base.group_portal')])]"/>
            <field name="email">orphan@example.com</field>
        </record>

    </data>
</odoo>
